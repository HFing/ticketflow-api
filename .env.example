# Docker Compose - PostgreSQL
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ticketflowdb

# Application
SERVER_PORT=8080
DB_URL=jdbc:postgresql://localhost:5432/ticketflowdb
DB_USERNAME=postgres
DB_PASSWORD=change-me
JPA_DDL_AUTO=update

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
JWT_SECRET_KEY=replace-with-a-secure-secret-key

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093

# Mail
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your-mail-username
MAIL_PASSWORD=your-mail-password
MAIL_FROM=no-reply@ticketflow.com

# VNPay sandbox
VNP_TMN_CODE=your-vnpay-terminal-code
VNP_HASH_SECRET=your-vnpay-hash-secret
VNP_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:8080/api/v1/payments/vnpay-callback
VNP_EXPIRE_MINUTES=5
VNP_EXPIRATION_SCAN_INTERVAL_MS=10000
