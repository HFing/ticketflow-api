# Docker Compose - PostgreSQL
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ticketflowdb

# Application
SERVER_PORT=8080
DB_URL=jdbc:postgresql://localhost:5432/ticketflowdb
DB_USERNAME=postgres
DB_PASSWORD=change-me
JPA_DDL_AUTO=update

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
JWT_SECRET_KEY=replace-with-a-secure-secret-key

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9093

# Mail
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your-mail-username
MAIL_PASSWORD=your-mail-password
MAIL_FROM=no-reply@ticketflow.com

# Payment & Stripe
PAYMENT_CURRENCY=VND
PAYMENT_HOLD_DURATION=PT5M
PAYMENT_EXPIRATION_SCAN_INTERVAL=PT5S
PAYMENT_EXPIRATION_BATCH_SIZE=100
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TEST_MODE_ONLY=true
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:8080/api/v1/payments/stripe/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/payment/cancel
